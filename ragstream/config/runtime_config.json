{
  "config_meta": {
    "config_name": "runtime_config",
    "version": "001",
    "scope": "global_runtime_defaults"
  },
  "memory_retrieval": {
    "enabled": true,
    "tag_catalog": [
      "Gold",
      "Green",
      "Black"
    ],
    "retrieval_source_modes": {
      "default": "QA",
      "options": {
        "QA": "Retrieve Q+A",
        "Q": "Retrieve only Q",
        "A": "Retrieve only A"
      }
    },
    "parent_score_weights": {
      "QA": {
        "answer": 0.55,
        "question": 0.35,
        "meta": 0.1
      },
      "A": {
        "answer": 0.85,
        "question": 0.0,
        "meta": 0.15
      },
      "Q": {
        "answer": 0.0,
        "question": 0.85,
        "meta": 0.15
      }
    },
    "working_memory": {
      "enabled": true,
      "max_pairs": 2,
      "latest_pair_max_tokens": 3000,
      "other_pair_max_tokens": 1500,
      "total_max_tokens": 4000,
      "exclude_tags": [
        "Black"
      ]
    },
    "episodic_memory": {
      "enabled": true,
      "max_total_records": 3,
      "max_gold_records": 1,
      "gold_max_tokens": 3000,
      "green_max_tokens": 1500,
      "green_semantic_weight": 0.75,
      "green_recency_weight": 0.25,
      "green_half_life_k": 10,
      "recency_enabled": true,
      "gold_bypass_recency": true,
      "exclude_tags": [
        "Black"
      ]
    },
    "direct_recall": {
      "enabled": true,
      "max_keys_per_run": 1,
      "gold_max_tokens": 3000,
      "green_max_tokens": 1500,
      "exclude_tags": [
        "Black"
      ]
    },
    "semantic_memory_chunks": {
      "enabled": true,
      "max_memory_chunks": 5,
      "semantic_weight": 0.9,
      "recency_weight": 0.1,
      "half_life_k": 10,
      "recency_enabled": true,
      "gold_bypass_recency": true,
      "exclude_tags": [
        "Black"
      ]
    }
  },
  "memory_compression": {
    "enabled": true,
    "effective_query": {
      "max_tokens": 300,
      "embedding_model": "text-embedding-3-small"
    },
    "episodic_memory": {
      "enabled": true,
      "max_tokens_total": 400,
      "question_max_tokens": 150,
      "window_size_sentences": 3,
      "window_overlap_sentences": 1,
      "redundancy_threshold": 0.92
    }
  },
  "memory_merge_synthesizer": {
    "enabled": true,
    "agent_id": "memory_synthesizer",
    "agent_version": "memory_synthesizer_001",
    "target_context_tokens": 700,
    "max_episodic_records": 3,
    "max_semantic_chunks": 5,
    "prompt_cache_key": "memory_synthesizer"
  },
  "memory_active_retrieval_brief": {
    "enabled": true,
    "reducer": {
      "max_tokens_total": 3000,
      "question_max_tokens": 1000,
      "window_size_sentences": 3,
      "window_overlap_sentences": 1,
      "redundancy_threshold": 0.92,
      "embedding_model": "text-embedding-3-small"
    },
    "activebrief_relevance_gate": {
      "enabled": true,
      "activebrief_threshold": 0.25,
      "pending_topic_threshold": 0.25
    },
    "llm": {
      "agent_id": "memory_activebrief_qa_summarizer",
      "init_agent_version": "memory_activebrief_qa_summarizer_init_001",
      "update_agent_version": "memory_activebrief_qa_summarizer_update_001",
      "target_brief_tokens": 700,
      "prompt_cache_key": "memory_activebrief_qa_summarizer"
    }
  },
  "document_retrieval": {
    "semantic_stage_max_total_chunks": 30,
    "max_document_chunks_for_a3": 25,
    "hard_embedding_floor": 0.2
  },
  "a4_condenser": {
    "max_output_tokens": 5000
  },
  "hard_rules": {
    "enabled": false,
    "planned_later": true
  }
}